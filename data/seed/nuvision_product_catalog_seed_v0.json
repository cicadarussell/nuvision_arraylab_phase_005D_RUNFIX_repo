  "technical_phase_clusters": [
    {
      "phase": "NVE_001",
      "name": "Catalogue ingestor V0",
      "goal": "Build reliable crawler/parser for Nuvision public Shopify catalogue pages, with permission/robots-safe behaviour.",
      "outputs": [
        "nuvision_products_raw.json",
        "nuvision_product_links.csv",
        "datasheet_link_queue.json"
      ],
      "pass_gates": [
        "all 19 public PV panel products captured",
        "inverter collection pagination captured",
        "battery collection pagination captured",
        "mounting collection pagination captured",
        "no duplicate product URLs",
        "all records have category, title, brand/vendor, URL, availability"
      ]
    },
    {
      "phase": "NVE_002",
      "name": "Datasheet fetch + manufacturer spec parser",
      "goal": "Download datasheets from Nuvision and original manufacturer sources; parse dimensions and electrical specs into typed fields.",
      "outputs": [
        "datasheets/raw",
        "datasheets/parsed_specs.json",
        "datasheet_parse_errors.json"
      ],
      "pass_gates": [
        "panel dimensions parsed for >=95% of panels",
        "panel Voc/Isc/Vmp/Imp parsed for >=90% of panels",
        "inverter MPPT/string limits parsed for top inverter families",
        "manual review queue for ambiguous PDFs"
      ]
    },
    {
      "phase": "NVE_003",
      "name": "Panel packing engine",
      "goal": "Use product dimensions to pack real modules on roof polygons/field polygons with portrait/landscape/mixed layouts.",
      "outputs": [
        "packing_engine.ts",
        "layout_score_report.json"
      ],
      "pass_gates": [
        "works for rectangles and arbitrary roof polygons",
        "respects setbacks/keep-outs",
        "compares large vs small module strategies",
        "exports panel coordinates"
      ]
    },
    {
      "phase": "NVE_004",
      "name": "3D roof + shade V0",
      "goal": "Manual roof pitch/azimuth and hand-drawn obstruction blocks, annual sun-path shadow animation.",
      "outputs": [
        "threejs_roof_scene",
        "annual_shade_matrix.json"
      ],
      "pass_gates": [
        "hourly sun path works",
        "manual building blocks cast shadows",
        "panel shade heatmap generated",
        "monthly shaded/unshaded graph displayed"
      ]
    },
    {
      "phase": "NVE_005",
      "name": "Inverter/string matching",
      "goal": "Suggest compatible inverters and string layouts using parsed panel and inverter electrical specs.",
      "outputs": [
        "string_design_engine.py",
        "inverter_shortlist.json",
        "warnings.json"
      ],
      "pass_gates": [
        "cold Voc check",
        "hot Vmp startup/MPPT check",
        "max current check",
        "MPPT grouping check",
        "engineer-review warning flags"
      ]
    },
    {
      "phase": "NVE_006",
      "name": "BOM + proposal pack",
      "goal": "Turn layout into Nuvision-stock-aware bill of materials, datasheet pack and customer/install proposal.",
      "outputs": [
        "bom.json",
        "proposal.pdf",
        "installer_pack.zip"
      ],
      "pass_gates": [
        "panels/inverter/mounting/core electrical items listed",
        "alternatives ranked by customer goal",
        "PDF/JSON export stable"
      ]
    },
    {
      "phase": "NVE_007",
      "name": "Advanced scan path",
      "goal": "Prototype LiDAR/drone/photogrammetry/Gaussian splat/Unreal visual layer after core product works.",
      "outputs": [
        "scan_import_spec.md",
        "unreal_visualiser_proof"
      ],
      "pass_gates": [
        "scan-to-roof-plane extraction tested",
        "3D customer visual demo runs",
        "no dependency on this for core quoting"
      ]
